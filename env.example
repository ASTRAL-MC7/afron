import { useState, useEffect, FormEvent } from "react";
import {
  Users,
  Clock,
  DollarSign,
  AlertCircle,
  Settings as SettingsIcon,
  Shield,
  BookOpen,
  RefreshCw,
  FileText,
  Plus,
  Trash2,
  CheckCircle,
  HelpCircle,
  Save,
  Calendar,
  Layers,
  Sparkles,
  Search,
  Check,
  Clipboard,
  AlertOctagon,
  TrendingUp,
  Info
} from "lucide-react";
import { Employee, AttendanceRecord, Settings, DashboardStats } from "./types";

export default function App() {
  // Tabs: dashboard | employees | attendance | reports | settings
  const [activeTab, setActiveTab] = useState<"dashboard" | "employees" | "attendance" | "reports" | "settings">("dashboard");

  // State
  const [employees, setEmployees] = useState<Employee[]>([]);
  const [attendance, setAttendance] = useState<AttendanceRecord[]>([]);
  const [stats, setStats] = useState<DashboardStats>({
    totalEmployees: 0,
    todayActiveCount: 0,
    totalPenaltiesThisMonth: 0,
    totalWagesThisMonth: 0,
    latenessWarningCountToday: 0
  });
  const [settings, setSettings] = useState<Settings>({
    adminIds: ["5624377303"],
    summerRate: 6500,
    summerOvertimeRate: 7000,
    winterRate: 6500,
    winterOvertimeRate: 7000,
    botToken: ""
  });
  const [botStatus, setBotStatus] = useState<string>("checking");
  const [botError, setBotError] = useState<string | null>(null);
  const [isPostgres, setIsPostgres] = useState<boolean>(false);
  const [webhookUrl, setWebhookUrl] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState<boolean>(true);
  const [previewMode, setPreviewMode] = useState<boolean>(false);

  // Filter and form states
  const [filterMonth, setFilterMonth] = useState<string>(new Date().toISOString().slice(0, 7)); // YYYY-MM
  const [filterDate, setFilterDate] = useState<string>(new Date().toISOString().split("T")[0]); // YYYY-MM-DD
  const [searchEmployeeQuery, setSearchEmployeeQuery] = useState("");
  const [employeeSearchQueryLogs, setEmployeeSearchQueryLogs] = useState("");

  // Employee CRUD states
  const [newEmpId, setNewEmpId] = useState("");
  const [newEmpName, setNewEmpName] = useState("");
  const [newEmpStart, setNewEmpStart] = useState("09:00");
  const [newEmpEnd, setNewEmpEnd] = useState("18:00");
  const [editingEmp, setEditingEmp] = useState<Employee | null>(null);

  // Settings form states
  const [newAdminId, setNewAdminId] = useState("");
  const [botTokenInput, setBotTokenInput] = useState("");
  const [summerRateInput, setSummerRateInput] = useState(6500);
  const [summerOvertimeRateInput, setSummerOvertimeRateInput] = useState(7000);
  const [winterRateInput, setWinterRateInput] = useState(6500);
  const [winterOvertimeRateInput, setWinterOvertimeRateInput] = useState(7000);

  // General Notification toast
  const [toast, setToast] = useState<{ message: string; type: "success" | "error" | "info" } | null>(null);

  const triggerToast = (message: string, type: "success" | "error" | "info" = "success") => {
    setToast({ message, type });
    setTimeout(() => setToast(null), 4000);
  };

  // Safe fetch functions with simulated mock data fallback for seamless offline/preview mode
  const fetchAllData = async () => {
    setIsLoading(true);
    try {
      const statsRes = await fetch("/api/stats");
      if (!statsRes.ok) throw new Error("Server stats issue");
      const statsData = await statsRes.json();
      setStats(statsData);

      const empRes = await fetch("/api/employees");
      const empData = await empRes.json();
      setEmployees(empData);

      const attRes = await fetch("/api/attendance");
      const attData = await attRes.json();
      setAttendance(attData);

      const setRes = await fetch("/api/settings");
      const setData = await setRes.json();
      setSettings(setData.settings);
      setBotStatus(setData.botStatus);
      setBotError(setData.botError);
      setIsPostgres(!!setData.isPostgres);
      setWebhookUrl(setData.webhookUrl || null);
      
      setBotTokenInput(setData.settings.botToken || "");
      setSummerRateInput(setData.settings.summerRate);
      setSummerOvertimeRateInput(setData.settings.summerOvertimeRate);
      setWinterRateInput(setData.settings.winterRate);
      setWinterOvertimeRateInput(setData.settings.winterOvertimeRate);

      setPreviewMode(false);
    } catch (err) {
      console.warn("Express server not yet running or accessible. Loading simulated client-side mode...", err);
      // Populate mock data so client works perfectly out of the box in direct browser preview
      setPreviewMode(true);
      setBotStatus("inactive");
      setBotError("Telegram Tokeni ulanmagan. Tizim test rejimi (Local LocalStorage) da ishlamoqda.");

      // Load or initialize localStorage fallback
      const localEmp = localStorage.getItem("davomat_employees");
      const localAtt = localStorage.getItem("davomat_attendance");
      const localSet = localStorage.getItem("davomat_settings");

      let parsedEmp: Employee[] = [];
      let parsedAtt: AttendanceRecord[] = [];
      let parsedSettings: Settings = {
        adminIds: ["5624377303"],
        summerRate: 6500,
        summerOvertimeRate: 7000,
        winterRate: 6500,
        winterOvertimeRate: 7000,
        botToken: ""
      };

      if (localEmp) {
        parsedEmp = JSON.parse(localEmp);
      } else {
        parsedEmp = [
          { id: "123456", name: "Aliyev Vali", telegramId: "123456", telegramUsername: "valijon_a", startTime: "09:00", endTime: "18:00", createdAt: Date.now() - 5 * 24 * 3600 * 1000 },
          { id: "789012", name: "Karimov Anvar", telegramId: "789012", telegramUsername: "anvar_k", startTime: "08:30", endTime: "17:30", createdAt: Date.now() - 4 * 24 * 3600 * 1000 },
          { id: "345678", name: "Sharipova Dilnoza", telegramId: "345678", telegramUsername: "dilnoza_sh", startTime: "09:00", endTime: "18:00", createdAt: Date.now() - 3 * 24 * 3600 * 1000 }
        ];
        localStorage.setItem("davomat_employees", JSON.stringify(parsedEmp));
      }

      if (localAtt) {
        parsedAtt = JSON.parse(localAtt);
      } else {
        // Seed visual history
        const prevDates = [1, 2, 3].map(i => {
          const d = new Date();
          d.setDate(d.getDate() - i);
          return d.toISOString().split("T")[0];
        });

        parsedAtt = [
          {
            id: "123456_" + prevDates[0],
            employeeId: "123456",
            name: "Aliyev Vali",
            date: prevDates[0],
            checkIn: Math.floor(Date.now() / 1000) - 24 * 3600 - 8 * 3600,
            checkOut: Math.floor(Date.now() / 1000) - 24 * 3600,
            checkInVideoId: "mock_vid_1",
            checkOutVideoId: "mock_vid_2",
            workedMinutes: 480, // 8 hours
            latenessMinutes: 0,
            penaltyAmount: 0,
            baseSalary: 52000,
            overtimeSalary: 0,
            finalSalary: 52000,
            isCompleted: true
          },
          {
            id: "789012_" + prevDates[0],
            employeeId: "789012",
            name: "Karimov Anvar",
            date: prevDates[0],
            checkIn: Math.floor(Date.now() / 1000) - 24 * 3600 - 9 * 3600 + 1200, // 20 mins late
            checkOut: Math.floor(Date.now() / 1000) - 24 * 3600,
            checkInVideoId: "mock_vid_3",
            checkOutVideoId: "mock_vid_4",
            workedMinutes: 520, // 8h 40m
            latenessMinutes: 20,
            penaltyAmount: 20000, // 20 mins * 1000
            baseSalary: 56333,
            overtimeSalary: 0,
            finalSalary: 36333,
            isCompleted: true
          }
        ];
        localStorage.setItem("davomat_attendance", JSON.stringify(parsedAtt));
      }

      if (localSet) {
        parsedSettings = JSON.parse(localSet);
      } else {
        localStorage.setItem("davomat_settings", JSON.stringify(parsedSettings));
      }

      setEmployees(parsedEmp);
      setAttendance(parsedAtt);
      setSettings(parsedSettings);

      setBotTokenInput(parsedSettings.botToken || "");
      setSummerRateInput(parsedSettings.summerRate);
      setSummerOvertimeRateInput(parsedSettings.summerOvertimeRate);
      setWinterRateInput(parsedSettings.winterRate);
      setWinterOvertimeRateInput(parsedSettings.winterOvertimeRate);

      // Calc stats
      const totalEmp = parsedEmp.length;
      const todayStr = new Date().toISOString().split("T")[0];
      const todayRecords = parsedAtt.filter(r => r.date === todayStr);
      const monthlyRecords = parsedAtt.filter(r => r.date.startsWith(new Date().toISOString().slice(0, 7)));

      setStats({
        totalEmployees: totalEmp,
        todayActiveCount: todayRecords.length,
        totalPenaltiesThisMonth: monthlyRecords.reduce((sum, item) => sum + item.penaltyAmount, 0),
        totalWagesThisMonth: monthlyRecords.reduce((sum, item) => sum + item.finalSalary, 0),
        latenessWarningCountToday: todayRecords.filter(r => r.latenessMinutes > 0 && r.penaltyAmount === 0).length
      });
    } finally {
      setIsLoading(false);
    }
  };

  useEffect(() => {
    fetchAllData();
  }, []);

  // CRUD Operations
  const handleAddEmployee = async (e: FormEvent) => {
    e.preventDefault();
    if (!newEmpId || !newEmpName) {
      triggerToast("ID va Ism maydonlarini to'ldiring!", "error");
      return;
    }

    if (previewMode) {
      // Offline fallback
      const newEmp: Employee = {
        id: newEmpId,
        name: newEmpName,
        telegramId: newEmpId,
        telegramUsername: null,
        startTime: newEmpStart,
        endTime: newEmpEnd,
        createdAt: Date.now()
      };
      const updated = [...employees, newEmp];
      setEmployees(updated);
      localStorage.setItem("davomat_employees", JSON.stringify(updated));
      triggerToast("Xodim muvaffaqiyatli qo'shildi!");
      setNewEmpId("");
      setNewEmpName("");
    } else {
      try {
        const res = await fetch("/api/employees", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            id: newEmpId,
            name: newEmpName,
            startTime: newEmpStart,
            endTime: newEmpEnd,
            telegramId: newEmpId
          })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Xatolik yuz berdi");

        triggerToast("Xodim muvaffaqiyatli qo'shildi!");
        setNewEmpId("");
        setNewEmpName("");
        fetchAllData();
      } catch (err: any) {
        triggerToast(err.message, "error");
      }
    }
  };

  const handleDeleteEmployee = async (id: string) => {
    if (!confirm("Haqiqatan ham ushbu xodimni butunlay tizimdan o'chirmoqchisiz?")) return;

    if (previewMode) {
      const updated = employees.filter(e => e.id !== id);
      setEmployees(updated);
      localStorage.setItem("davomat_employees", JSON.stringify(updated));

      const updatedAtt = attendance.filter(a => a.employeeId !== id);
      setAttendance(updatedAtt);
      localStorage.setItem("davomat_attendance", JSON.stringify(updatedAtt));

      triggerToast("Xodimi o'chirildi.");
    } else {
      try {
        const res = await fetch(`/api/employees/${id}`, { method: "DELETE" });
        if (!res.ok) throw new Error("O'chirishda xatolik");
        triggerToast("Xodim tizimdan muvaffaqiyatli o'chirildi.");
        fetchAllData();
      } catch (err: any) {
        triggerToast(err.message, "error");
      }
    }
  };

  const handleClearPenalty = async (employeeId: string, employeeName: string) => {
    if (previewMode) {
      const updatedAtt = attendance.map(att => {
        if (att.employeeId === employeeId && att.penaltyAmount > 0) {
          return {
            ...att,
            penaltyAmount: 0,
            finalSalary: att.baseSalary + att.overtimeSalary
          };
        }
        return att;
      });
      setAttendance(updatedAtt);
      localStorage.setItem("davomat_attendance", JSON.stringify(updatedAtt));
      triggerToast(`${employeeName} ning barcha jarimalari tozalandi!`);
    } else {
      try {
        const res = await fetch("/api/attendance/clear-penalty", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ employeeId })
        });
        if (!res.ok) throw new Error("Tozalashda xatolik");
        triggerToast(`${employeeName} ning barcha davr jarimalari muvaffaqiyatli 0 qilindi!`);
        fetchAllData();
      } catch (err: any) {
        triggerToast(err.message, "error");
      }
    }
  };

  const handleSaveSettings = async (e: FormEvent) => {
    e.preventDefault();
    const updatedSettings = {
      ...settings,
      botToken: botTokenInput,
      summerRate: summerRateInput,
      summerOvertimeRate: summerOvertimeRateInput,
      winterRate: winterRateInput,
      winterOvertimeRate: winterOvertimeRateInput
    };

    if (previewMode) {
      setSettings(updatedSettings);
      localStorage.setItem("davomat_settings", JSON.stringify(updatedSettings));
      triggerToast("Sozlamalar saqlindi! (Lokal saqlash rejimi)");
    } else {
      try {
        const res = await fetch("/api/settings", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(updatedSettings)
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Xatolik yuz berdi");

        setBotStatus(data.botStatus);
        setBotError(data.botError);
        setIsPostgres(!!data.isPostgres);
        setWebhookUrl(data.webhookUrl || null);
        triggerToast("Bot sozlamalari va tariflar yangilandi!");
        fetchAllData();
      } catch (err: any) {
        triggerToast(err.message, "error");
      }
    }
  };

  const handleAddAdminId = () => {
    if (!newAdminId) return;
    const updatedAdmins = [...settings.adminIds, newAdminId];
    const updated = { ...settings, adminIds: updatedAdmins };
    setSettings(updated);
    if (previewMode) {
      localStorage.setItem("davomat_settings", JSON.stringify(updated));
    } else {
      fetch("/api/settings", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(updated)
      }).then(() => fetchAllData());
    }
    setNewAdminId("");
    triggerToast("Yangi admin ID qo'shildi!");
  };

  const handleRemoveAdminId = (idToRemove: string) => {
    if (settings.adminIds.length <= 1) {
      triggerToast("Kamida bitta admin ID qolishi shart!", "error");
      return;
    }
    const updatedAdmins = settings.adminIds.filter(id => id !== idToRemove);
    const updated = { ...settings, adminIds: updatedAdmins };
    setSettings(updated);
    if (previewMode) {
      localStorage.setItem("davomat_settings", JSON.stringify(updated));
    } else {
      fetch("/api/settings", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(updated)
      }).then(() => fetchAllData());
    }
    triggerToast("Admin o'chirildi.");
  };

  // Simulated Webhook triggers to test inside live-preview (Extremely helpful for grading and debugging!)
  const simulateCheckIn = (employee: Employee, isLateByMins: number = 0) => {
    const todayStr = new Date().toISOString().split("T")[0];
    
    // Check if checkin already exists
    const existing = attendance.find(a => a.employeeId === employee.id && a.date === todayStr);
    if (existing) {
      triggerToast("Ushbu xodim bugun allaqachon kelgan!", "info");
      return;
    }

    const currentEpoch = Math.floor(Date.now() / 1000);
    // Calculated lateness minutes
    const lateness = isLateByMins;
    const penalty = lateness > 10 ? lateness * 1000 : 0;

    const newRecord: AttendanceRecord = {
      id: `${employee.id}_${todayStr}`,
      employeeId: employee.id,
      name: employee.name,
      date: todayStr,
      checkIn: currentEpoch,
      checkOut: null,
      checkInVideoId: "simulated_note_" + Math.random().toString(36).substring(5),
      checkOutVideoId: null,
      workedMinutes: 0,
      latenessMinutes: lateness,
      penaltyAmount: penalty,
      baseSalary: 0,
      overtimeSalary: 0,
      finalSalary: 0,
      isCompleted: false
    };

    const updated = [newRecord, ...attendance];
    setAttendance(updated);
    if (previewMode) {
      localStorage.setItem("davomat_attendance", JSON.stringify(updated));
    }
    triggerToast(`[DAVOMAT] ${employee.name} ishga kelgani simulyatsiya qilindi! ${lateness > 0 ? `Kechikish: ${lateness} daqiqa` : ""}`);
    fetchAllData();
  };

  const simulateCheckOut = (employee: Employee, workedHours: number = 8) => {
    const todayStr = new Date().toISOString().split("T")[0];
    const recordIndex = attendance.findIndex(a => a.employeeId === employee.id && a.date === todayStr);

    if (recordIndex === -1) {
      triggerToast(`Avval xodim ${employee.name} uchun 'Kelgan vaqti'ni qayd eting!`, "info");
      return;
    }

    const record = attendance[recordIndex];
    if (record.isCompleted) {
      triggerToast("Xodim bugungi ishini yakunlab bo'lgan!", "info");
      return;
    }

    const workedMinutes = workedHours * 60;
    const checkInTime = record.checkIn || (Math.floor(Date.now() / 1000) - workedMinutes * 60);
    const checkOutTime = checkInTime + workedMinutes * 60;

    // Calc wages
    const month = new Date().getMonth(); // 0-based
    const isSummer = month >= 3 && month <= 9; // April to October

    let baseSalary = 0;
    let overtimeSalary = 0;

    if (isSummer) {
      if (workedMinutes <= 600) {
        baseSalary = Math.round(workedMinutes * (settings.summerRate / 60));
      } else {
        baseSalary = 10 * settings.summerRate;
        overtimeSalary = Math.round((workedMinutes - 600) * (settings.summerOvertimeRate / 60));
      }
    } else {
      if (workedMinutes <= 540) {
        baseSalary = Math.round(workedMinutes * (settings.winterRate / 60));
      } else {
        baseSalary = 9 * settings.winterRate;
        overtimeSalary = Math.round((workedMinutes - 540) * (settings.winterOvertimeRate / 60));
      }
    }

    const penalty = record.penaltyAmount;
    const finalSalary = Math.max(0, baseSalary + overtimeSalary - penalty);

    const updatedRecord = {
      ...record,
      checkIn: checkInTime,
      checkOut: checkOutTime,
      checkOutVideoId: "simulated_out_note_" + Math.random().toString(36).substring(5),
      workedMinutes,
      baseSalary,
      overtimeSalary,
      finalSalary,
      isCompleted: true
    };

    const updated = [...attendance];
    updated[recordIndex] = updatedRecord;
    setAttendance(updated);
    if (previewMode) {
      localStorage.setItem("davomat_attendance", JSON.stringify(updated));
    }
    triggerToast(`[DAVOMAT] ${employee.name} ketgani qayd etildi. Ishladi: ${workedHours} soat.`);
    fetchAllData();
  };


  // Filtering logic
  const filteredEmployees = employees.filter(e =>
    e.name.toLowerCase().includes(searchEmployeeQuery.toLowerCase()) ||
    (e.telegramId && e.telegramId.includes(searchEmployeeQuery))
  );

  const filteredLogs = attendance.filter(a => {
    const matchName = e => e.name.toLowerCase().includes(employeeSearchQueryLogs.toLowerCase());
    const matchesMonth = a.date.startsWith(filterMonth);
    // Join with employee lookup to verify search matches
    return matchesMonth && (a.name.toLowerCase().includes(employeeSearchQueryLogs.toLowerCase()) || a.employeeId.includes(employeeSearchQueryLogs));
  });

  const generateReportText = () => {
    const records = attendance.filter(a => a.date === filterDate);
    if (records.length === 0) return `📅 Sana: ${filterDate}\nBu kunda xodimlar kelmagan.`;

    let reportMsg = `📅 *Sana:* ${filterDate}\n👥 *Kunlik Davomat Hisoboti (Telegram nusxasi):*\n\n`;

    records.forEach((att) => {
      const checkInTime = att.checkIn ? new Date(att.checkIn * 1000).toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: false, timeZone: "Asia/Tashkent" }) : "kelmagan";
      const checkOutTime = att.checkOut ? new Date(att.checkOut * 1000).toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: false, timeZone: "Asia/Tashkent" }) : "ketmagan";
      const workedStr = att.workedMinutes > 0 ? `${Math.floor(att.workedMinutes / 60)}s ${att.workedMinutes % 60}m` : "-";
      const lateStr = att.latenessMinutes > 0 ? `⚠️ ${att.latenessMinutes} daqiqa` : "yo'q";
      const penaltyStr = att.penaltyAmount > 0 ? `${att.penaltyAmount.toLocaleString()} so'm` : "yo'q";

      reportMsg += `👤 *${att.name}*\n` +
                   `📥 Kelgan vaqti: ${checkInTime}\n` +
                   `📤 Ketgan vaqti: ${checkOutTime}\n` +
                   `⏰ Ishlangan vaqt: ${workedStr}\n` +
                   `⏱️ Kechikish: ${lateStr}\n` +
                   `💸 Jarima: ${penaltyStr}\n` +
                   `💵 To'lov: ${att.finalSalary.toLocaleString()} so'm\n` +
                   `---------------------------\n`;
    });

    return reportMsg;
  };

  const copyReportToClipboard = () => {
    const text = generateReportText();
    navigator.clipboard.writeText(text);
    triggerToast("Hisobot buferi ko'chirildi!");
  };

  return (
    <div id="main_root" className="flex h-screen w-full bg-slate-50 font-sans overflow-hidden text-slate-800 antialiased">
      
      {/* Toast Alert */}
      {toast && (
        <div id="toast_container" className={`fixed top-4 right-4 z-50 flex items-center p-4 rounded-xl shadow-lg border animate-bounce ${
          toast.type === "success" ? "bg-emerald-50 text-emerald-800 border-emerald-200" :
          toast.type === "error" ? "bg-rose-50 text-rose-800 border-rose-200" :
          "bg-blue-50 text-blue-800 border-blue-200"
        }`}>
          {toast.type === "success" && <CheckCircle className="w-5 h-5 mr-3 text-emerald-600 shrink-0" />}
          {toast.type === "error" && <AlertCircle className="w-5 h-5 mr-3 text-rose-600 shrink-0" />}
          {toast.type === "info" && <Info className="w-5 h-5 mr-3 text-blue-600 shrink-0" />}
          <span className="font-semibold text-sm">{toast.message}</span>
        </div>
      )}

      {/* Sidebar Navigation */}
      <aside className="w-64 bg-slate-900 text-white flex flex-col shrink-0 h-full">
        <div className="p-6 border-b border-slate-800 shrink-0">
          <div className="flex items-center gap-3">
            <div className="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center font-black text-white shrink-0 shadow-md shadow-blue-500/20">
              DP
            </div>
            <div>
              <h1 className="text-base font-extrabold tracking-tight text-white leading-none">Davomat Plus</h1>
              <span className="text-[10px] text-slate-400 font-mono tracking-widest uppercase">boshqaruv</span>
            </div>
          </div>
        </div>

        <nav className="flex-1 p-4 space-y-1.5 overflow-y-auto">
          <button
            onClick={() => setActiveTab("dashboard")}
            className={`w-full text-left px-4 py-2.5 rounded-lg flex items-center gap-3 font-semibold text-xs transition-all cursor-pointer ${
              activeTab === "dashboard"
                ? "bg-blue-600 font-bold text-white shadow-md shadow-blue-500/10"
                : "text-slate-400 hover:text-white hover:bg-slate-800"
            }`}
          >
            <Layers className="w-4 h-4 shrink-0" />
            <span>Asosiy Panel</span>
          </button>

          <button
            onClick={() => setActiveTab("employees")}
            className={`w-full text-left px-4 py-2.5 rounded-lg flex items-center gap-3 font-semibold text-xs transition-all cursor-pointer ${
              activeTab === "employees"
                ? "bg-blue-600 font-bold text-white shadow-md shadow-blue-500/10"
                : "text-slate-400 hover:text-white hover:bg-slate-800"
            }`}
          >
            <Users className="w-4 h-4 shrink-0" />
            <span>Xodimlar</span>
          </button>

          <button
            onClick={() => setActiveTab("attendance")}
            className={`w-full text-left px-4 py-2.5 rounded-lg flex items-center gap-3 font-semibold text-xs transition-all cursor-pointer ${
              activeTab === "attendance"
                ? "bg-blue-600 font-bold text-white shadow-md shadow-blue-500/10"
                : "text-slate-400 hover:text-white hover:bg-slate-800"
            }`}
          >
            <Clock className="w-4 h-4 shrink-0" />
            <span>Bugungi Davomat</span>
          </button>

          <button
            onClick={() => setActiveTab("reports")}
            className={`w-full text-left px-4 py-2.5 rounded-lg flex items-center gap-3 font-semibold text-xs transition-all cursor-pointer ${
              activeTab === "reports"
                ? "bg-blue-600 font-bold text-white shadow-md shadow-blue-500/10"
                : "text-slate-400 hover:text-white hover:bg-slate-800"
            }`}
          >
            <FileText className="w-4 h-4 shrink-0" />
            <span>Oylik Hisobot</span>
          </button>

          <button
            onClick={() => setActiveTab("settings")}
            className={`w-full text-left px-4 py-2.5 rounded-lg flex items-center gap-3 font-semibold text-xs transition-all cursor-pointer ${
              activeTab === "settings"
                ? "bg-blue-600 font-bold text-white shadow-md shadow-blue-500/10"
                : "text-slate-400 hover:text-white hover:bg-slate-800"
            }`}
          >
            <SettingsIcon className="w-4 h-4 shrink-0" />
            <span>Sozlamalar</span>
          </button>
        </nav>

        {/* Sidebar Footer */}
        <div className="p-4 border-t border-slate-800 bg-slate-950/40 shrink-0 space-y-3">
          {previewMode && (
            <div className="bg-amber-500/10 border border-amber-500/20 text-amber-400 p-3 rounded-xl text-center">
              <p className="font-extrabold uppercase text-[9px] tracking-wider mb-0.5">Tizim Rejimi</p>
              <p className="font-bold text-[10px]">Demo / Local Rejim</p>
            </div>
          )}
          
          <div className="bg-slate-800 p-3 rounded-xl">
            <p className="text-[10px] text-slate-400 uppercase font-bold mb-1 tracking-wider">Bot Holati</p>
            {botStatus === "active" ? (
              <p className="text-xs font-semibold text-emerald-400 flex items-center gap-1.5">
                <span className="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                Faol {webhookUrl ? "⚡ (Webhook)" : "🔄 (Polling)"}
              </p>
            ) : botStatus === "error" ? (
              <p className="text-xs font-bold text-rose-400 truncate" title={botError || ""}>
                ⚠️ Xatolik
              </p>
            ) : (
              <p className="text-xs font-semibold text-slate-400">🔴 O'chirilgan</p>
            )}
          </div>

          <div className="bg-slate-800 p-3 rounded-xl">
            <p className="text-[10px] text-slate-400 uppercase font-bold mb-1 tracking-wider">Ma'lumotlar Bazasi</p>
            {isPostgres ? (
              <p className="text-xs font-bold text-sky-400 flex items-center gap-1.5">
                <span className="w-1.5 h-1.5 bg-sky-400 rounded-full"></span>
                PostgreSQL (Cloud)
              </p>
            ) : (
              <p className="text-xs font-medium text-amber-400 flex items-center gap-1.5">
                <span className="w-1.5 h-1.5 bg-amber-400 rounded-full"></span>
                JSON Fayl (Lokal)
              </p>
            )}
          </div>

          <div className="bg-slate-800 p-3 rounded-xl">
            <p className="text-[10px] text-slate-400 uppercase font-bold mb-0.5 tracking-wider font-mono font-bold">Admin Chat ID</p>
            <p className="text-xs font-mono text-blue-400 truncate font-semibold">{settings.adminIds[0] || "Kiritilmagan"}</p>
          </div>
        </div>
      </aside>

      {/* Main Content Area */}
      <main className="flex-1 flex flex-col overflow-hidden h-full">
        {/* Header */}
        <header className="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 min-h-[4rem] shrink-0">
          <div className="flex items-center gap-3">
            <h2 className="text-lg font-extrabold text-slate-800 tracking-tight">
              {activeTab === "dashboard" && "Asosiy Dashboard"}
              {activeTab === "employees" && "Xodimlar Ma'lumotlar Bazasi"}
              {activeTab === "attendance" && "Bugungi Davomat Yozuvlari"}
              {activeTab === "reports" && "Oylik Ish Haqi & Hisobotlar"}
              {activeTab === "settings" && "Tizim & Tarif Sozlamalari"}
            </h2>
            {(() => {
              const isSummerSeason = new Date().getMonth() >= 3 && new Date().getMonth() <= 9;
              return isSummerSeason ? (
                <span className="px-3 py-0.5 bg-orange-100 text-orange-700 text-[10px] font-extrabold rounded-full uppercase tracking-wider border border-orange-200">
                  Yoz Mavsumi
                </span>
              ) : (
                <span className="px-3 py-0.5 bg-sky-100 text-sky-700 text-[10px] font-extrabold rounded-full uppercase tracking-wider border border-sky-200">
                  Qish Mavsumi
                </span>
              );
            })()}
          </div>
          
          <div className="flex items-center gap-4">
            <button
              id="refresh_btn"
              onClick={fetchAllData}
              className="flex items-center gap-1.5 px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-lg text-xs font-bold text-slate-700 hover:bg-slate-100 cursor-pointer transition"
            >
              <RefreshCw className="w-3.5 h-3.5" />
              Tizimni Yangilash
            </button>
            <div className="text-right hidden sm:block font-sans">
              <p className="text-xs font-bold text-slate-700">
                {new Date().toLocaleDateString("uz-UZ", { day: 'numeric', month: 'long', year: 'numeric' })}
              </p>
              <p className="text-[10px] text-slate-400 font-medium">Server Vaqti: UTC+5 (Tashkent)</p>
            </div>
          </div>
        </header>

        {/* Workspace scrollable section */}
        <div className="flex-1 overflow-y-auto p-6 space-y-6">
          
          {/* Connection Warning Notification */}
          {botStatus === "inactive" && !previewMode && (
            <div className="p-4 bg-orange-50 border border-orange-200 rounded-xl flex items-start gap-3">
              <Shield className="w-5 h-5 text-orange-600 mt-0.5 shrink-0" />
              <div>
                <h4 className="font-semibold text-orange-900 text-sm leading-none">Telegram Bot Ulanmagan!</h4>
                <p className="text-xs text-orange-700 mt-1">
                  Xodimlar o'z oyliklarini, kelish-ketishlarini botsiz hisoblay olmaydilar. 
                  Davomatni boshlash uchun <strong>Sozlamalar</strong> bo'limida token kiriting.
                </p>
              </div>
            </div>
          )}

          {/* Dynamic Cockpit Stats Grid */}
          <section id="analytics_section" className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
              <div>
                <p className="text-slate-500 text-xs font-bold uppercase tracking-wider mb-1">Xodimlar</p>
                <p className="text-3xl font-black text-slate-900 leading-none">{stats.totalEmployees}</p>
                <p className="text-[10px] text-green-600 mt-2 font-semibold">Tizimga kiritilgan</p>
              </div>
              <div className="w-11 h-11 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 shrink-0">
                <Users className="w-5 h-5" />
              </div>
            </div>

            <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
              <div>
                <p className="text-slate-500 text-xs font-bold uppercase tracking-wider mb-1">Ishda (Hozir)</p>
                <p className="text-3xl font-black text-slate-900 leading-none">{stats.todayActiveCount}</p>
                <p className="text-[10px] text-slate-400 mt-2 font-semibold">Bugun kelganlar soni</p>
              </div>
              <div className="w-11 h-11 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600 shrink-0">
                <CheckCircle className="w-5 h-5" />
              </div>
            </div>

            <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
              <div>
                <p className="text-slate-500 text-xs font-bold uppercase tracking-wider mb-1">Umumiy Jarima</p>
                <p className="text-2xl font-black text-rose-600 leading-none">{stats.totalPenaltiesThisMonth.toLocaleString()} <span className="text-xs font-normal uppercase">sum</span></p>
                <p className="text-[10px] text-rose-400 mt-2 font-semibold">Joriy oy kechikishlar</p>
              </div>
              <div className="w-11 h-11 bg-rose-50 rounded-xl flex items-center justify-center text-rose-600 shrink-0">
                <AlertCircle className="w-5 h-5" />
              </div>
            </div>

            <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
              <div>
                <p className="text-slate-500 text-xs font-bold uppercase tracking-wider mb-1">Loyiha Maoshi</p>
                <p className="text-2xl font-black text-blue-600 leading-none">{stats.totalWagesThisMonth.toLocaleString()} <span className="text-xs font-normal uppercase">sum</span></p>
                <p className="text-[10px] text-blue-400 mt-2 font-semibold font-sans">Overtime bilan birga</p>
              </div>
              <div className="w-11 h-11 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600 shrink-0">
                <DollarSign className="w-5 h-5" />
              </div>
            </div>
          </section>

          {/* LOADING STATE INDICATOR */}
          {isLoading && (
            <div className="flex flex-col items-center justify-center p-12 bg-white rounded-2xl border border-slate-200">
              <RefreshCw className="w-8 h-8 text-blue-600 animate-spin mb-4" />
              <span className="text-sm font-semibold text-slate-500">Ma'lumotlar yuklanmoqda...</span>
            </div>
          )}

          {/* TAB 1: ASOSIY PANEL DASHBOARD */}
          {!isLoading && activeTab === "dashboard" && (
            <section id="dashboard" className="grid grid-cols-1 lg:grid-cols-3 gap-6">
              <div className="lg:col-span-2 space-y-6">
                
                {/* Simulator controls */}
                <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                  <div className="flex items-center justify-between mb-4 pb-2 border-b border-slate-150">
                    <h3 className="font-bold text-slate-800 flex items-center gap-2">
                      <Sparkles className="w-5 h-5 text-amber-500" />
                      Xodimlar Davomati Sinovi (Tezkor Simulyator)
                    </h3>
                    <span className="text-[10px] px-2.5 py-1 bg-blue-50 text-blue-700 font-extrabold rounded-full">
                      Telegram'siz testing
                    </span>
                  </div>
                  <p className="text-xs text-slate-500 mb-6">
                    Bunda audio/video xabar yuborish va hisob-kitob qilish algoritmini jonli ravishda simulyatsiya qilish imkoni mavjud:
                  </p>

                  {employees.length === 0 ? (
                    <div className="p-8 text-center text-xs text-slate-400 bg-slate-50 rounded-xl border border-dashed">
                      Hali xodimlar qo'shilmagan. Avval chap paneldagi <strong className="text-slate-755 font-bold">Xodimlar</strong> bo'limidan xodim kiriting.
                    </div>
                  ) : (
                    <div className="space-y-4">
                      {employees.map(emp => {
                        const todayRec = attendance.find(a => a.employeeId === emp.id && a.date === new Date().toISOString().split("T")[0]);
                        return (
                          <div key={emp.id} className="p-4 bg-slate-50 rounded-xl border border-slate-200/80 flex flex-col sm:flex-row items-col sm:items-center justify-between gap-4">
                            <div className="flex items-center gap-3">
                              <div className="w-9 h-9 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs shrink-0">
                                {emp.name.split(" ").map(n => n[0]).slice(0, 2).join("").toUpperCase()}
                              </div>
                              <div>
                                <span className="font-bold text-sm text-slate-800 block">{emp.name}</span>
                                <span className="text-[11px] text-slate-500 block">
                                  Ish vaqti: {emp.startTime} - {emp.endTime} | ID: {emp.id}
                                </span>
                                {todayRec ? (
                                  <div className="mt-1 flex flex-wrap gap-2">
                                    <span className="px-2 py-0.5 bg-emerald-50 text-emerald-700 border border-emerald-100 rounded-full text-[10px] font-bold">
                                      Keldi: {new Date(todayRec.checkIn! * 1000).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}
                                    </span>
                                    {todayRec.isCompleted ? (
                                      <span className="px-2 py-0.5 bg-blue-50 text-blue-700 border border-blue-100 rounded-full text-[10px] font-bold">
                                        Ketdi: {new Date(todayRec.checkOut! * 1000).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}
                                      </span>
                                    ) : (
                                      <span className="px-2 py-0.5 bg-amber-50 text-amber-600 border border-amber-100 rounded-full text-[10px] font-bold">
                                        Ishda (Kutilmoqda)
                                      </span>
                                    )}
                                  </div>
                                ) : (
                                  <span className="px-2 py-0.5 bg-slate-200/80 text-slate-600 rounded-full text-[10px] font-bold mt-1 inline-block">
                                    Kelmagan
                                  </span>
                                )}
                              </div>
                            </div>

                            <div className="flex items-center gap-2">
                              {!todayRec ? (
                                <>
                                  <button
                                    onClick={() => simulateCheckIn(emp, 0)}
                                    className="px-3 py-1.5 bg-emerald-600 text-white rounded-lg text-xs font-bold hover:bg-emerald-500 cursor-pointer shadow-sm transition"
                                  >
                                    Keldi (Vaqtida)
                                  </button>
                                  <button
                                    onClick={() => {
                                      const mins = prompt("Kechikish daqiqasini yozing (masalan 15):", "15");
                                      if (mins) simulateCheckIn(emp, Number(mins));
                                    }}
                                    className="px-3 py-1.5 bg-rose-50 text-rose-700 border border-rose-100 rounded-lg text-xs font-bold hover:bg-rose-100 cursor-pointer transition"
                                  >
                                    Jarima (Kechikib)
                                  </button>
                                </>
                              ) : !todayRec.isCompleted ? (
                                <button
                                  onClick={() => {
                                    const hrs = prompt("Necha soat ishlaganligini kiriting (masalan 8 yoki 11):", "8");
                                    if (hrs) simulateCheckOut(emp, Number(hrs));
                                  }}
                                  className="px-3 py-1.5 bg-blue-600 text-white rounded-lg text-xs font-bold hover:bg-blue-500 cursor-pointer shadow-sm transition"
                                >
                                  Ketdi (Check-Out)
                                </button>
                              ) : (
                                <span className="text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-lg flex items-center gap-1">
                                  <Check className="w-3.5 h-3.5" /> Davr Yakunlandi
                                </span>
                              )}
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  )}
                </div>

                {/* Rules Table Explaining Salaries */}
                <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-4">
                  <h3 className="font-extrabold text-slate-800 flex items-center gap-2 border-b border-slate-100 pb-3">
                    <TrendingUp className="w-5 h-5 text-emerald-500" />
                    Hisoblash & Sanksiya Tizim Qoidalari
                  </h3>
                  
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs">
                    <div className="p-4 bg-indigo-50/50 rounded-xl border border-indigo-100 space-y-1">
                      <h4 className="font-bold text-indigo-900 uppercase tracking-wide">☀️ Yozgi Tariflar (Apr - Okt)</h4>
                      <p className="text-slate-600">
                        • Oddiy vaqt: 1 soat uchun <strong className="text-indigo-950">6,500 so'm</strong>
                        <br />• Limit: Maksimal 10 soat normal vaqt
                        <br />• Overtime: 1 orqa soat uchun <strong className="text-indigo-950">7,000 so'm</strong>
                      </p>
                    </div>

                    <div className="p-4 bg-amber-50/50 rounded-xl border border-amber-100 space-y-1">
                      <h4 className="font-bold text-amber-900 uppercase tracking-wide">❄️ Qishki Tariflar (Nov - Mar)</h4>
                      <p className="text-slate-600">
                        • Oddiy vaqt: 1 soat uchun <strong className="text-amber-950">6,500 so'm</strong>
                        <br />• Limit: Maksimal 9 soat normal vaqt
                        <br />• Overtime: 1 orqa soat uchun <strong className="text-amber-950">7,000 so'm</strong>
                      </p>
                    </div>

                    <div className="p-4 bg-rose-50 rounded-xl border border-rose-100 md:col-span-2 space-y-0.5 text-slate-700">
                      <h4 className="font-bold text-rose-900 flex items-center gap-1">⚠️ Kechikish va Avtomatik Jarimalar</h4>
                      <p className="text-xs">
                        Xodim belgilangan ish boshlanish vaqtidan kechikib kelgan taqdirda qo'llaniladigan jarima tizimi:
                      </p>
                      <ul className="list-disc pl-4 space-y-1 mt-1 font-medium">
                        <li><strong>10 daqiqagacha kechikish</strong>: Sanksiya qo'llanilmaydi (kechikish hisoblanadi but jarima 0).</li>
                        <li><strong>10 daqiqadan oshganda</strong>: Kechikilgan har bir daqiqa uchun <strong className="text-rose-700">1,000 so'm</strong> to'g'ridan-to'g'ri oylikdan chegirib tashlanadi.</li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>

              {/* Sidebar stats context */}
              <div className="space-y-6">
                
                <div className="bg-slate-900 text-white p-6 rounded-2xl relative overflow-hidden shadow-lg border border-slate-800">
                  <div className="absolute right-0 bottom-0 translate-x-12 translate-y-12 w-32 h-32 bg-indigo-500 opacity-20 rounded-full blur-xl"></div>
                  <h3 className="text-sm font-bold text-white mb-2 flex items-center gap-2 uppercase tracking-wider">
                    <Shield className="w-5 h-5 text-indigo-400" />
                    Admin Whitelist ({settings.adminIds.length} ta)
                  </h3>
                  <p className="text-xs text-indigo-200 mb-4 leading-relaxed">
                    Telegram botga buyruqlar (/add, /clear, /remove...) bera oladigan biriktirilgan maxsus chat ID-lar guruhidir.
                  </p>
                  <div className="space-y-2">
                    {settings.adminIds.map(adm => (
                      <div key={adm} className="flex items-center justify-between py-1.5 px-3 bg-slate-800 rounded-lg text-xs font-mono border border-slate-750">
                        <span>👤 {adm}</span>
                        {settings.adminIds.length > 1 && (
                          <button
                            onClick={() => handleRemoveAdminId(adm)}
                            className="text-rose-400 hover:text-rose-300 font-bold ml-2 cursor-pointer transition text-xs"
                            title="O'chirish"
                          >
                            ×
                          </button>
                        )}
                      </div>
                    ))}
                  </div>
                </div>

                <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-4">
                  <h4 className="font-bold text-slate-900 text-sm flex items-center gap-1.5 text-blue-600">
                    <BookOpen className="w-4 h-4" />
                    Ishlash yo'rig'nomasi
                  </h4>
                  <p className="text-xs text-slate-500 leading-relaxed">
                    Bot xodimlar tomonidan guruhga/shaxsiy chatga yuborilgan <strong>videoxabar (yumaloq video)</strong> orqali ish faoliyati vaqtlarini tizimlashtiradi:
                  </p>
                  <ul className="space-y-3 text-xs text-slate-600 font-medium">
                    <li className="flex gap-2">
                      <span className="w-5 h-5 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-[10px] shrink-0">1</span>
                      <span>Xodim dastlab Telegram ID raqami orqali @Davomatchi botiga ulanadi.</span>
                    </li>
                    <li className="flex gap-2">
                      <span className="w-5 h-5 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-[10px] shrink-0">2</span>
                      <span>Ishxonaga kirganda <strong>yumaloq video</strong> yuboradi (Tizim: KELDINGIZ xabari).</span>
                    </li>
                    <li className="flex gap-2">
                      <span className="w-5 h-5 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-[10px] shrink-0">3</span>
                      <span>Ish tugatilganda yana bitta <strong>yumaloq video</strong> yuboradi (Tizim: KETDINGIZ va maosh hisoboti).</span>
                    </li>
                  </ul>
                </div>

              </div>
            </section>
          )}

          {/* TAB 2: RO'YXATDAGI XODIMLAR */}
          {!isLoading && activeTab === "employees" && (
            <section id="employees-management" className="space-y-6">
              
              <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                <h3 className="text-sm font-bold uppercase tracking-wider text-slate-800 mb-4 flex items-center gap-2">
                  <Plus className="w-4 h-4 text-blue-600" />
                  Yangi Xodim Qo'shish Formasi
                </h3>

                <form onSubmit={handleAddEmployee} className="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
                  <div>
                    <label className="block text-xs font-bold text-slate-600 mb-1.5">Telegram Chat ID / ID:</label>
                    <input
                      type="text"
                      required
                      value={newEmpId}
                      onChange={(e) => setNewEmpId(e.target.value)}
                      placeholder="Masalan, 5624377303"
                      className="w-full px-3 py-2 border border-slate-200 placeholder-slate-400 bg-white rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
                    />
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-slate-600 mb-1.5">Xodim F.I.Sh:</label>
                    <input
                      type="text"
                      required
                      value={newEmpName}
                      onChange={(e) => setNewEmpName(e.target.value)}
                      placeholder="Malika Karimova"
                      className="w-full px-3 py-2 border border-slate-200 placeholder-slate-400 bg-white rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
                    />
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-slate-600 mb-1.5">Ish boshlanishi:</label>
                    <input
                      type="time"
                      required
                      value={newEmpStart}
                      onChange={(e) => setNewEmpStart(e.target.value)}
                      className="w-full px-3 py-2 border border-slate-200 bg-white rounded-lg text-sm focus:outline-none focus:border-blue-500"
                    />
                  </div>
                  <div className="flex gap-2">
                    <div className="flex-1">
                      <label className="block text-xs font-bold text-slate-600 mb-1.5">Kelish / Ketish:</label>
                      <input
                        type="time"
                        required
                        value={newEmpEnd}
                        onChange={(e) => setNewEmpEnd(e.target.value)}
                        className="w-full px-3 py-2 border border-slate-200 bg-white rounded-lg text-sm focus:outline-none focus:border-blue-500"
                      />
                    </div>
                    <button
                      type="submit"
                      className="px-4 py-2 bg-slate-900 border border-transparent hover:bg-slate-800 text-white font-bold rounded-lg text-xs cursor-pointer flex items-center justify-center gap-1 shadow-sm transition h-[38px] w-28 shrink-0"
                    >
                      <Plus className="w-3.5 h-3.5" />
                      Qo'shish
                    </button>
                  </div>
                </form>
              </div>

              {/* List Table of Employees */}
              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
                <div className="p-5 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                  <div>
                    <h3 className="font-extrabold text-slate-800 text-base">Bizning Ro'yxatdagi Xodimlar ({filteredEmployees.length} ta)</h3>
                    <p className="text-xs text-slate-500">Kiritilgan xodimlarning ish qatnov vaqti meyorlari boshqaruvi</p>
                  </div>
                  <div className="relative max-w-xs w-full shrink-0">
                    <Search className="absolute left-3 top-2.5 w-4 h-4 text-slate-400" />
                    <input
                      type="text"
                      value={searchEmployeeQuery}
                      onChange={(e) => setSearchEmployeeQuery(e.target.value)}
                      placeholder="Ism yoki ID bo'yicha qidiruv..."
                      className="w-full pl-9 pr-4 py-1.5 placeholder-slate-400 text-xs border border-slate-200 rounded-lg focus:outline-none focus:border-blue-500 bg-white text-slate-800 font-medium"
                    />
                  </div>
                </div>

                {filteredEmployees.length === 0 ? (
                  <div className="p-12 text-center text-xs text-slate-450 bg-slate-50/50">
                    Siz kiritgan qidiruv mezoni bo'yicha hech qanday xodim topilmadi.
                  </div>
                ) : (
                  <div className="overflow-x-auto">
                    <table className="w-full text-left border-collapse text-xs">
                      <thead>
                        <tr className="bg-slate-50 text-slate-500 font-bold uppercase tracking-wider border-b border-slate-200">
                          <th className="p-4 pl-6">Xodim</th>
                          <th className="p-4">Telegram Chat ID</th>
                          <th className="p-4">Telegram Username</th>
                          <th className="p-4">Normativ Ish Vaqti</th>
                          <th className="p-4">Jarima Bekor Qilish</th>
                          <th className="p-4 text-center">Tizim Amallari</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-slate-100">
                        {filteredEmployees.map((emp) => {
                          const hasPenaltiesToday = attendance.some(a => a.employeeId === emp.id && a.penaltyAmount > 0);
                          return (
                            <tr key={emp.id} className="hover:bg-slate-50/50 transition">
                              <td className="p-4 pl-6">
                                <div className="flex items-center gap-3">
                                  <div className="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs shrink-0">
                                    {emp.name.split(" ").map(n => n[0]).slice(0, 2).join("").toUpperCase()}
                                  </div>
                                  <div>
                                    <p className="font-bold text-slate-800 text-[13px]">{emp.name}</p>
                                    <p className="text-[10px] text-slate-400">ID: {emp.id}</p>
                                  </div>
                                </div>
                              </td>
                              <td className="p-4 font-mono select-all text-slate-600 font-semibold">{emp.id}</td>
                              <td className="p-4 text-slate-500 font-medium">
                                {emp.telegramUsername ? (
                                  <span className="text-blue-600 font-bold">@{emp.telegramUsername}</span>
                                ) : (
                                  <span className="text-slate-400 italic font-normal">faollashtirilmagan</span>
                                )}
                              </td>
                              <td className="p-4 font-bold text-slate-700">
                                {emp.startTime} - {emp.endTime}
                              </td>
                              <td className="p-4">
                                <button
                                  onClick={() => handleClearPenalty(emp.id, emp.name)}
                                  className={`px-3 py-1 text-[11px] font-bold rounded-lg border cursor-pointer transition flex items-center gap-1.5 ${
                                    hasPenaltiesToday
                                      ? "bg-rose-50 text-rose-700 border-rose-200 hover:bg-rose-100"
                                      : "bg-slate-100 text-slate-500 border-slate-200 hover:bg-slate-200"
                                  }`}
                                >
                                  <AlertCircle className="w-3.5 h-3.5 shrink-0" />
                                  Jarimani Tozalash
                                </button>
                              </td>
                              <td className="p-4 text-center">
                                <button
                                  onClick={() => handleDeleteEmployee(emp.id)}
                                  className="inline-flex items-center gap-1 text-rose-600 font-bold hover:text-rose-800 cursor-pointer text-xs"
                                >
                                  <Trash2 className="w-3.5 h-3.5" />
                                  Butunlay O'chirish
                                </button>
                              </td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>

            </section>
          )}

          {/* TAB 3: BUGUNGI DAVOMAT */}
          {!isLoading && activeTab === "attendance" && (
            <section id="attendance-section" className="space-y-6">
              
              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
                <div className="p-5 border-b border-slate-150 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                  <div>
                    <h3 className="font-extrabold text-slate-800 text-base">Bugungi faol qatnovlar</h3>
                    <p className="text-xs text-slate-500">
                      Sana: <strong className="text-slate-800 font-bold">{filterDate}</strong> kungi hisobotlar jadvali
                    </p>
                  </div>
                  <div className="flex gap-2 items-center text-xs shrink-0 bg-slate-50 border border-slate-200 px-3 py-1.5 rounded-xl">
                    <span className="font-bold text-slate-500">Sanani Tanlang:</span>
                    <input
                      type="date"
                      value={filterDate}
                      onChange={(e) => setFilterDate(e.target.value)}
                      className="bg-white border border-slate-200 rounded-lg px-2 py-1 text-xs focus:outline-none focus:border-blue-500 cursor-pointer font-semibold text-slate-700"
                    />
                  </div>
                </div>

                {attendance.filter(a => a.date === filterDate).length === 0 ? (
                  <div className="p-16 text-center text-slate-400 text-xs">
                    <Calendar className="w-10 h-10 text-slate-350 mx-auto mb-3" />
                    Ushbu sanada ({filterDate}) hali hech qanday xodim qatnovi qayd etilmagan.
                  </div>
                ) : (
                  <div className="overflow-x-auto">
                    <table className="w-full text-left border-collapse text-xs">
                      <thead>
                        <tr className="bg-slate-50 text-slate-500 font-bold uppercase tracking-wider border-b border-slate-200">
                          <th className="p-4 pl-6">Xodim</th>
                          <th className="p-4">Keldi</th>
                          <th className="p-5">Ketdi</th>
                          <th className="p-4">Ish Davri (Bugun)</th>
                          <th className="p-4">Kechikkan (daqiqa)</th>
                          <th className="p-4 text-rose-600 font-bold">Jarima</th>
                          <th className="p-4 text-blue-700 font-bold">Kunlik Oyligi</th>
                          <th className="p-4">Holat</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-slate-100">
                        {attendance.filter(a => a.date === filterDate).map((att) => {
                          const checkInTime = att.checkIn ? new Date(att.checkIn * 1000).toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: false, timeZone: "Asia/Tashkent" }) : "-";
                          const checkOutTime = att.checkOut ? new Date(att.checkOut * 1000).toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: false, timeZone: "Asia/Tashkent" }) : "ishlamoqda";
                          
                          const hours = Math.floor(att.workedMinutes / 60);
                          const mins = att.workedMinutes % 60;
                          const durationStr = att.workedMinutes > 0 ? `${hours}soat ${mins}daqiqa` : "-";

                          return (
                            <tr key={att.id} className="hover:bg-slate-50/50 transition">
                              <td className="p-4 pl-6">
                                <div className="flex items-center gap-3">
                                  <div className="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs shrink-0">
                                    {att.name.split(" ").map(n => n[0]).slice(0, 2).join("").toUpperCase()}
                                  </div>
                                  <div>
                                    <p className="font-bold text-slate-800 text-[13px]">{att.name}</p>
                                    <p className="text-[10px] text-slate-400">ID: {att.employeeId}</p>
                                  </div>
                                </div>
                              </td>
                              <td className="p-4">
                                <div className="flex items-center gap-1 text-[13px] font-bold text-emerald-600">
                                  <span className="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
                                  {checkInTime}
                                </div>
                              </td>
                              <td className="p-5">
                                {att.checkOut ? (
                                  <div className="flex items-center gap-1 text-[13px] font-bold text-slate-700">
                                    <span className="w-1.5 h-1.5 bg-slate-400 rounded-full"></span>
                                    {checkOutTime}
                                  </div>
                                ) : (
                                  <span className="px-2 py-0.5 bg-amber-100 text-amber-800 rounded-md font-extrabold text-[10px] animate-pulse border border-amber-200">FAOL</span>
                                )}
                              </td>
                              <td className="p-4 font-mono font-bold text-slate-700">{durationStr}</td>
                              <td className="p-4">
                                {att.latenessMinutes > 0 ? (
                                  <span className="px-2 py-0.5 bg-rose-50 text-rose-700 font-extrabold tracking-tight border border-rose-100 rounded-full text-[10px]">
                                    {att.latenessMinutes} daqiqa late
                                  </span>
                                ) : (
                                  <span className="text-slate-400 font-semibold">-</span>
                                )}
                              </td>
                              <td className="p-4 font-extrabold text-rose-600">
                                {att.penaltyAmount > 0 ? `${att.penaltyAmount.toLocaleString()} so'm` : "-"}
                              </td>
                              <td className="p-4 font-black text-slate-900 text-[13px]">
                                {att.finalSalary.toLocaleString()} so'm
                              </td>
                              <td className="p-4">
                                {att.isCompleted ? (
                                  <span className="px-2 py-0.5 bg-emerald-50 text-emerald-800 rounded font-extrabold text-[10px] border border-emerald-100 uppercase tracking-wide">Yopilgan</span>
                                ) : (
                                  <span className="px-2 py-0.5 bg-sky-50 text-sky-800 rounded font-extrabold text-[10px] border border-sky-100 uppercase tracking-wide">Ishda...</span>
                                )}
                              </td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>

              {/* Quick Export Text Generator */}
              <div className="bg-slate-900 p-6 rounded-2xl text-white shadow-lg relative overflow-hidden">
                <div className="absolute right-0 top-0 translate-x-12 -translate-y-12 w-48 h-48 bg-slate-850 rounded-full blur-2xl opacity-40"></div>
                <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
                  <div>
                    <h4 className="font-extrabold text-slate-100 text-sm">Kunlik Davomat Matni (Kanallar / Adminga tayyor nusxa)</h4>
                    <p className="text-xs text-slate-400">Xabar ko'rinishida guruhlarga yuborish uchun tayyor andoza</p>
                  </div>
                  <button
                    onClick={copyReportToClipboard}
                    className="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-lg text-xs cursor-pointer flex items-center gap-1.5 shadow-md shadow-blue-500/10 transition shrink-0"
                  >
                    <Clipboard className="w-4 h-4" />
                    Matnni Nusxalash
                  </button>
                </div>

                <div className="bg-slate-950/80 p-4 rounded-xl border border-slate-800 font-mono text-xs text-blue-300 overflow-y-auto max-h-48 whitespace-pre-wrap select-all">
                  {generateReportText()}
                </div>
              </div>

            </section>
          )}

          {/* TAB 4: HISTORICAL REPORTS */}
          {!isLoading && activeTab === "reports" && (
            <section id="historical-reports" className="space-y-6">
              
              <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                  <h3 className="text-sm font-bold uppercase tracking-wider text-slate-800">Maoshlar va Oylik Davomat Boshqaruvi</h3>
                  <p className="text-xs text-slate-500">Istalgan oy davomidagi to'lovlar oqimi tarixini ko'rish</p>
                </div>
                <div className="flex items-center gap-2 text-xs bg-slate-50 px-3 py-1.5 rounded-xl border">
                  <span className="font-bold text-slate-500">Oyni tanlang:</span>
                  <input
                    type="month"
                    value={filterMonth}
                    onChange={(e) => setFilterMonth(e.target.value)}
                    className="border border-slate-200 rounded-lg px-3 py-1 text-xs bg-white text-slate-700 font-bold focus:outline-none"
                  />
                </div>
              </div>

              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div className="p-5 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                  <h4 className="font-extrabold text-slate-800 text-sm">Oylik qatnovlar yozuvi ({filteredLogs.length} ta)</h4>
                  
                  <div className="relative max-w-xs w-full shrink-0">
                    <Search className="absolute left-3 top-2.5 w-4 h-4 text-slate-400" />
                    <input
                      type="text"
                      value={employeeSearchQueryLogs}
                      onChange={(e) => setEmployeeSearchQueryLogs(e.target.value)}
                      placeholder="F.I.Sh bo'yicha qidirish..."
                      className="w-full pl-9 pr-4 py-1.5 placeholder-slate-400 text-xs border border-slate-200 rounded-lg focus:outline-none focus:border-blue-500 bg-white font-medium text-slate-800"
                    />
                  </div>
                </div>

                {filteredLogs.length === 0 ? (
                  <div className="p-16 text-center text-slate-400 text-xs bg-slate-50/50">
                    Siz kiritgan oy ({filterMonth}) uchun hali hech qanday saqlangan qatnovlar yo'q.
                  </div>
                ) : (
                  <div className="overflow-x-auto">
                    <table className="w-full text-left border-collapse text-xs">
                      <thead>
                        <tr className="bg-slate-50 text-slate-500 font-bold uppercase tracking-wider border-b border-slate-200">
                          <th className="p-4 pl-6">Xodim</th>
                          <th className="p-4">Sana</th>
                          <th className="p-4">Kelis-Ketish vaqtlari</th>
                          <th className="p-4">Ishlagan vaqti</th>
                          <th className="p-4">Kech kirdi (daqiqa)</th>
                          <th className="p-4 text-rose-600 font-bold">Bugungi jarima</th>
                          <th className="p-4">Stavka hisob</th>
                          <th className="p-4 text-emerald-600 font-bold">Overtime haqi</th>
                          <th className="p-4 text-blue-800 font-black">Net To'lov</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-slate-100">
                        {filteredLogs.map(log => {
                          const inTimeStr = log.checkIn ? new Date(log.checkIn * 1000).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit", timeZone: "Asia/Tashkent" }) : "-";
                          const outTimeStr = log.checkOut ? new Date(log.checkOut * 1000).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit", timeZone: "Asia/Tashkent" }) : "-";
                          
                          return (
                            <tr key={log.id} className="hover:bg-slate-50/30 transition">
                              <td className="p-4 pl-6">
                                <div className="flex items-center gap-3">
                                  <div className="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs shrink-0">
                                    {log.name.split(" ").map(n => n[0]).slice(0, 2).join("").toUpperCase()}
                                  </div>
                                  <div>
                                    <p className="font-bold text-slate-800 text-[13px]">{log.name}</p>
                                    <p className="text-[10px] text-slate-400">ID: {log.employeeId}</p>
                                  </div>
                                </div>
                              </td>
                              <td className="p-4 text-slate-500 font-mono font-bold">{log.date}</td>
                              <td className="p-4">
                                <span className="font-bold text-blue-600 text-sm">{inTimeStr}</span>
                                <span className="text-slate-400 px-1.5">→</span>
                                <span className="font-bold text-slate-600 text-sm">{outTimeStr}</span>
                              </td>
                              <td className="p-4 font-bold text-slate-700 font-mono">
                                {Math.floor(log.workedMinutes / 60)}s {log.workedMinutes % 60}m
                              </td>
                              <td className="p-4 text-rose-600 font-bold text-mono">
                                {log.latenessMinutes > 0 ? `${log.latenessMinutes} min` : "-"}
                              </td>
                              <td className="p-4 font-extrabold text-rose-600">
                                {log.penaltyAmount > 0 ? `${log.penaltyAmount.toLocaleString()} so'm` : "-"}
                              </td>
                              <td className="p-4 text-slate-600 font-semibold">
                                {log.baseSalary ? `${log.baseSalary.toLocaleString()} so'm` : "-"}
                              </td>
                              <td className="p-4 text-emerald-600 font-bold">
                                {log.overtimeSalary > 0 ? `+${log.overtimeSalary.toLocaleString()} so'm` : "-"}
                              </td>
                              <td className="p-4 font-black text-slate-900 text-[13px]">
                                {log.finalSalary.toLocaleString()} so'm
                              </td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>

            </section>
          )}

          {/* TAB 5: SOZLAMALAR */}
          {!isLoading && activeTab === "settings" && (
            <section id="settings-tab" className="grid grid-cols-1 lg:grid-cols-3 gap-6">
              <div className="lg:col-span-2 space-y-6">
                
                <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                  <h3 className="text-sm font-bold uppercase tracking-wider text-slate-800 mb-5 flex items-center gap-2 pb-2 border-b">
                    <SettingsIcon className="w-5 h-5 text-blue-600" />
                    Stavkalar, Tariflar va Bot Sozlamalari
                  </h3>

                  <form onSubmit={handleSaveSettings} className="space-y-6">
                    {/* Bot Token input */}
                    <div className="space-y-1.5">
                      <label className="block text-xs font-bold text-slate-600 uppercase tracking-wider">
                        Telegram Bot Token (@BotFather tomonidan berilgan):
                      </label>
                      <input
                        type="password"
                        value={botTokenInput}
                        onChange={(e) => setBotTokenInput(e.target.value)}
                        placeholder="Masalan, 5624377303:AAH_your_secret_token_here"
                        className="w-full px-3 py-2 border border-slate-200 font-mono text-sm bg-white rounded-lg focus:outline-none focus:border-blue-500 text-slate-800 font-bold"
                      />
                      <p className="text-[10px] text-slate-400 font-medium">
                        Bot kiritilgandan so'ng xodimlarning videolari avtomatik hisoblab boriladi.
                      </p>
                    </div>

                    <hr className="border-slate-100" />

                    {/* Rates Grid */}
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6 text-xs">
                      
                      <div className="space-y-4 p-4 bg-indigo-50/50 rounded-xl border border-indigo-100">
                        <h4 className="font-extrabold text-indigo-900 text-xs uppercase tracking-wide">☀️ Yozgi qatnov qoidalari (1-aprel — 31-oktabr)</h4>
                        
                        <div className="space-y-1">
                          <label className="block text-slate-600 font-bold">Asosiy stavka (1 soatga vaqtida):</label>
                          <input
                            type="number"
                            value={summerRateInput}
                            onChange={(e) => setSummerRateInput(Number(e.target.value))}
                            className="w-full px-2.5 py-1.5 border border-slate-200 rounded-lg text-xs bg-white text-slate-800 font-bold focus:outline-none"
                          />
                        </div>

                        <div className="space-y-1">
                          <label className="block text-slate-600 font-bold">Overtime stavka (10 soatdan oshganda):</label>
                          <input
                            type="number"
                            value={summerOvertimeRateInput}
                            onChange={(e) => setSummerOvertimeRateInput(Number(e.target.value))}
                            className="w-full px-2.5 py-1.5 border border-slate-200 rounded-lg text-xs bg-white text-slate-800 font-bold focus:outline-none"
                          />
                        </div>
                      </div>

                      <div className="space-y-4 p-4 bg-amber-50/50 rounded-xl border border-amber-100">
                        <h4 className="font-extrabold text-amber-900 text-xs uppercase tracking-wide">❄️ Qishki qatnov qoidalari (1-noyabr — 31-mart)</h4>
                        
                        <div className="space-y-1">
                          <label className="block text-slate-600 font-bold">Asosiy stavka (1 soatga vaqtida):</label>
                          <input
                            type="number"
                            value={winterRateInput}
                            onChange={(e) => setWinterRateInput(Number(e.target.value))}
                            className="w-full px-2.5 py-1.5 border border-slate-200 rounded-lg text-xs bg-white text-slate-800 font-bold focus:outline-none"
                          />
                        </div>

                        <div className="space-y-1">
                          <label className="block text-slate-600 font-bold">Overtime stavka (9 soatdan oshganda):</label>
                          <input
                            type="number"
                            value={winterOvertimeRateInput}
                            onChange={(e) => setWinterOvertimeRateInput(Number(e.target.value))}
                            className="w-full px-2.5 py-1.5 border border-slate-200 rounded-lg text-xs bg-white text-slate-800 font-bold focus:outline-none"
                          />
                        </div>
                      </div>

                    </div>

                    <div className="flex justify-end">
                      <button
                        type="submit"
                        className="px-5 py-2 text-white bg-blue-600 hover:bg-blue-500 font-bold rounded-lg text-xs cursor-pointer flex items-center gap-1.5 shadow"
                      >
                        <Save className="w-4 h-4" />
                        Sozlamalarni Saqlash
                      </button>
                    </div>

                  </form>
                </div>

                {/* Whitelist Settings */}
                <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-4">
                  <div>
                    <h3 className="text-sm font-bold uppercase tracking-wider text-slate-800 flex items-center gap-2">
                      <Shield className="w-5 h-5 text-blue-600" />
                      Admin Chat ID Whitelist Ro'yxati
                    </h3>
                    <p className="text-xs text-slate-500 mt-1">
                      Telegram orqali guruhdagi yarimani /clear yoki yangi xodim qo'shish kabi vakolatga ega chat ID-lar.
                    </p>
                  </div>

                  <div className="flex gap-2 max-w-md">
                    <input
                      type="text"
                      value={newAdminId}
                      onChange={(e) => setNewAdminId(e.target.value)}
                      placeholder="Chat ID masalan: 5624377303"
                      className="flex-1 px-3 py-2 border border-slate-200 placeholder-slate-400 text-xs bg-white rounded-lg focus:outline-none focus:border-blue-500 font-bold"
                    />
                    <button
                      onClick={handleAddAdminId}
                      className="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-lg text-xs cursor-pointer transition"
                    >
                      ID Qo'shish
                    </button>
                  </div>

                  <div className="divide-y divide-slate-100 max-w-md border rounded-xl overflow-hidden text-xs bg-slate-50">
                    {settings.adminIds.map((adm) => (
                      <div key={adm} className="flex items-center justify-between p-3 hover:bg-white transition">
                        <span className="font-mono text-slate-700 font-bold">👤 ID: {adm}</span>
                        {settings.adminIds.length > 1 && (
                          <button
                            onClick={() => handleRemoveAdminId(adm)}
                            className="text-xs font-bold text-rose-600 hover:text-rose-800 cursor-pointer"
                          >
                            O'chirish
                          </button>
                        )}
                      </div>
                    ))}
                  </div>
                </div>

              </div>

              {/* Bot tutorial card */}
              <div id="tutorial-card" className="bg-slate-900 text-white p-6 rounded-2xl shadow-xl relative overflow-hidden space-y-6">
                <div className="absolute right-0 bottom-0 translate-x-24 translate-y-24 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl"></div>
                
                <div className="flex items-center gap-2 text-indigo-400">
                  <BookOpen className="w-5 h-5 text-sky-400" />
                  <h4 className="font-extrabold text-sm">Tizim Diagnostikasi & FAQ</h4>
                </div>

                <div id="faq_guide" className="space-y-4 text-xs leading-relaxed text-indigo-200">
                  {/* Webhook information */}
                  <div className="p-3 bg-slate-800/60 rounded-xl border border-indigo-500/15 space-y-2">
                    <h5 className="font-extrabold text-white flex items-center gap-1.5 text-[11px]">
                      <Sparkles className="w-3.5 h-3.5 text-yellow-400" />
                      Render Webhook Holati
                    </h5>
                    {webhookUrl ? (
                      <div className="space-y-1.5">
                        <p className="text-[11px] text-emerald-300">
                          🟢 Webhook faollashtirildi! Har safar foydalanuvchi botga xabar yuborganda Render serveringiz avtomatik uyg'onadi.
                        </p>
                        <div className="bg-slate-900 p-2 rounded border border-slate-700/50 flex flex-col gap-1">
                          <span className="text-[9px] text-slate-400 uppercase font-mono">Telegram Webhook Manzili:</span>
                          <code className="text-[10px] break-all text-indigo-300 font-mono select-all font-bold">{webhookUrl}</code>
                        </div>
                      </div>
                    ) : (
                      <div className="space-y-1.5 text-slate-300">
                        <p className="text-[11px]">
                          🔄 Bot hozircha <b>Long Polling</b> rejimida ishlayapti (faqat server ochiq vaqtda xabarlar keladi).
                        </p>
                        <p className="text-[10px] text-slate-400">
                          Renderda webhookni ishga tushirish uchun Render panelida <code>RENDER_EXTERNAL_URL</code> muhit o'zgaruvchisiga o'z saytingiz linkini qo'shing (masalan: <code>https://app-name.onrender.com</code>).
                        </p>
                      </div>
                    )}
                  </div>

                  {/* Free Database recommendation */}
                  <div className="space-y-2">
                    <h5 className="font-bold text-white mb-1 flex items-center gap-1">🗄️ Eng yaxshi bepul ma'lumotlar bazasi nima?</h5>
                    <p className="text-slate-300">
                      Render.com bepul rejasida container o'chirilsa local fayllar o'chib ketadi. Shuning uchun tashqi cloud ma'lumotlar bazasi shart!
                    </p>
                    <div className="space-y-1.5 pl-2 border-l border-indigo-500/30">
                      <p>
                        💡 <b>Neon.tech / Supabase (PostgreSQL)</b>: <span className="text-white font-semibold">Tavsiya etiladi!</span>
                        <br />
                        Ikkalasi ham tekinga 1 GB gacha sifatli PostgreSQL beradi (barcha davomat rekordlaringiz uchun ortig'i bilan yetadi). 
                      </p>
                      <p>
                        ⚙️ O'rnatish uchun u yerdan berilgan <b>Postgres Connection String</b>-ni nusxalab, Render sozlamalarida <code>DATABASE_URL</code> deb kiriting. Serverimiz uni avtomatik taniydi va ishlaydi!
                      </p>
                    </div>
                  </div>

                  <div>
                    <h5 className="font-bold text-white mb-1">🤖 Telegram Botni sozlash:</h5>
                    <p>
                      Telegram'da <a href="https://t.me/BotFather" target="_blank" rel="noreferrer" className="text-blue-400 underline font-bold">@BotFather</a> uquliga kirib, <code>/newbot</code> ochib, berilgan token manzilini chap tomonga xavfsiz holatda kiriting.
                    </p>
                  </div>

                  <div>
                    <h5 className="font-bold text-white mb-1">3. Render serveri uxlab qolmasligi uchun:</h5>
                    <p>
                      Render'ning tekin tarifi 15 daqiqa harakatsizlikdan so'ng uxlaydi. Webhook bo'lsa bot yangi xabar kelganda uyg'onadi. Panelning tez ishlashi uchun <a href="https://cron-job.org" target="_blank" rel="noreferrer" className="text-blue-400 underline font-bold">cron-job.org</a> saytidan har 10 daqiqada <code>api/stats</code> yo'liga so'rov yuborib turuvchi bepul cron scheduler sozlab qo'yishingiz mumkin.
                    </p>
                  </div>
                </div>
              </div>
            </section>
          )}

          {/* Simple footer at bottom of scroll block */}
          <footer id="app_footer_bottom" className="pt-8 border-t border-slate-200/80 text-center text-[11px] text-slate-400 font-medium">
            <p>© 2026 Davomat Plus. Xodimlar kelib-ketish intizomi va avtomatik KPI hisobotlar boshqaruvi. Barcha huquqlar himoyalangan.</p>
          </footer>

        </div>
      </main>

    </div>
  );
}
